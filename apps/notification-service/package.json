{
  "name": "@org/notification-service",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": ["{options.outputPath}"],
        "defaultConfiguration": "production",
        "options": {
          "platform": "node",
          "outputPath": "apps/notification-service/dist",
          "format": ["cjs"],
          "bundle": false,
          "main": "apps/notification-service/src/main.ts",
          "tsConfig": "apps/notification-service/tsconfig.app.json",
          "assets": [],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": { ".js": ".js" }
          }
        },
        "configurations": {
          "development": {},
          "production": {
            "esbuildOptions": {
              "sourcemap": false,
              "outExtension": { ".js": ".js" }
            }
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": ["build"],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/notification-service/dist/package.json",
          "{workspaceRoot}/apps/notification-service/dist/bun.lock"
        ],
        "options": { "buildTarget": "build" }
      },
      "copy-workspace-modules": {
        "dependsOn": ["build"],
        "cache": true,
        "outputs": ["{workspaceRoot}/apps/notification-service/dist/workspace_modules"],
        "executor": "@nx/js:copy-workspace-modules",
        "options": { "buildTarget": "build" }
      },
      "prune": {
        "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": ["build"],
        "options": {
          "buildTarget": "@org/notification-service:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": { "buildTarget": "@org/notification-service:build:development" },
          "production": { "buildTarget": "@org/notification-service:build:production" }
        }
      },
      "test": {
        "options": { "passWithNoTests": true }
      }
    }
  },
  "dependencies": {
    "@org/kafka_client": "*",
    "@org/logger": "*",
    "@org/monitoring": "*",
    "@org/types": "*",
    "@sendgrid/mail": "^8.1.3",
    "twilio": "^5.3.4"
  }
}
