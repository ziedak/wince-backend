{
  "name": "@org/enrichment-session-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@org/enrichment-session"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "packages/db/apps/enrichment-session-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@org/enrichment-session:build",
          "@org/enrichment-session:serve"
        ]
      }
    }
  }
}
