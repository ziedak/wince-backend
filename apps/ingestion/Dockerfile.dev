# syntax=docker/dockerfile:1.7

FROM rust:1-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    cmake \
    libcurl4-openssl-dev \
    libssl-dev \
    libsasl2-dev \
    pkg-config \
    zlib1g-dev \
  && rm -rf /var/lib/apt/lists/*

RUN cargo install cargo-watch --locked

WORKDIR /workspace

COPY Cargo.toml Cargo.lock ./
COPY .cargo ./.cargo
COPY apps/ingestion/Cargo.toml apps/ingestion/Cargo.toml
COPY apps/ingestion/src apps/ingestion/src

ENV CARGO_TARGET_DIR=/workspace/dist/target \
    RUST_LOG=info \
    PORT=3001 \
    KAFKA_HOSTS=kafka:29092 \
    KAFKA_TOPIC_RAW=raw.events \
    REDIS_URL=redis://redis:6379 \
    REDIS_BLOOM_KEY=idem:bloom

EXPOSE 3001

CMD ["sh", "-lc", "cargo watch -x 'run -p ingestion'"]