{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug @org/analytics-consumer with Nx",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["nx", "serve", "@org/analytics-consumer"],
      "env": {
        "NODE_OPTIONS": "--inspect=9229"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/apps/analytics-consumer/dist/**/*.(m|c|)js",
        "!**/node_modules/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug @org/enrichment-session with Nx",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["nx", "serve", "@org/enrichment-session"],
      "env": {
        "NODE_OPTIONS": "--inspect=9230"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/packages/db/apps/enrichment-session/dist/**/*.(m|c|)js",
        "!**/node_modules/**"
      ]
    }
  ]
}
